# Git
.git/
.gitignore

# Frontend (not needed for backend deployment)
frontend/

# Data files — only static seed/reference files go into the image.
# The ML model, corpus DB, and shards live on the Fly.io persistent volume
# and are never bundled into the Docker image.
data/
!data/.gitkeep
!data/english_words.txt
!data/tagalog_words.txt
!data/multi_word_slang.json
!data/slang_seeds.json
!data/discovered_slang.json
# Python caches
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# IDE & OS
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# Config
fly.toml
.envrc
.env
*.md
migrate_to_sqlite.py
