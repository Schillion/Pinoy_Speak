# Copy this file to .env.local and fill in your values.
# .env.local is never committed to git.

# URL of your deployed Python backend (Railway).
# Get this from: Railway dashboard → your service → Settings → Networking → Public URL
# Example: https://pinoyspeak-production.up.railway.app
PYTHON_API_URL=https://your-backend.up.railway.app

# Groq API key — primary LLM for the chatbot (free tier: 100k tokens/day, no credit card).
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini API key — fallback LLM (free tier: 1,500 req/day, no credit card).
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Ollama — optional local/self-hosted LLM fallback.
# Run Ollama locally: https://ollama.com  then: ollama pull llama3.2
# Set OLLAMA_URL to use it (e.g. http://localhost:11434 for local dev).
OLLAMA_URL=
OLLAMA_MODEL=llama3.2
